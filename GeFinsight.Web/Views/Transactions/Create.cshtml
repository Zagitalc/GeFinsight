@model TransactionFormViewModel
@{
    ViewData["Title"] = "New transaction";
}

<h1 class="page-title mb-3">New Transaction</h1>

<form method="post" class="workspace-panel p-4 mb-4" style="max-width: 640px;">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Date" class="form-label"></label>
        <input asp-for="Date" type="date" class="form-control" required />
        <span asp-validation-for="Date" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CategoryName" class="form-label"></label>
        <select asp-for="CategoryName" asp-items="Model.Categories" class="form-select" required></select>
        <span asp-validation-for="CategoryName" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" class="form-select">
            <option value="Expense">Expense</option>
            <option value="Income">Income</option>
        </select>
        <span asp-validation-for="Type" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" type="number" step="0.01" min="0.01" inputmode="decimal" class="form-control" required />
        <span asp-validation-for="Amount" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Note" class="form-label"></label>
        <input asp-for="Note" type="text" class="form-control" maxlength="500" />
        <span asp-validation-for="Note" class="text-danger small"></span>
    </div>
    <div>
        <button type="submit" class="btn btn-primary">Save Transaction</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>
