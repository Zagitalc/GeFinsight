@{
    ViewData["Title"] = "Dashboard";
    var report      = (ReportData)ViewBag.Report;
    var ruleResults = (List<RuleResult>)ViewBag.RuleResults;
    var insight     = (string)(ViewBag.Insight ?? string.Empty);
    var insightHeading = (string)(ViewBag.InsightHeading ?? "Insight");
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4">
    <div>
        <p class="text-muted mb-1">Current month</p>
        <h1 class="page-title mb-0">Dashboard</h1>
    </div>
    <a class="btn btn-primary" asp-controller="Transactions" asp-action="Create">Add Transaction</a>
</div>

<div class="metric-grid mb-4">
    <div class="metric-panel">
        <div class="metric-label">Income This Month</div>
        <div class="metric-value text-success">£@report.TotalIncome.ToString("N2")</div>
    </div>
    <div class="metric-panel">
        <div class="metric-label">Expenses This Month</div>
        <div class="metric-value text-danger">£@report.TotalExpenses.ToString("N2")</div>
    </div>
    <div class="metric-panel">
        <div class="metric-label">Net</div>
        <div class="metric-value">£@report.NetAmount.ToString("N2")</div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <section class="workspace-panel h-100">
            <div class="panel-header">Spending By Category</div>
            <div class="p-3">
                @if (report.ByCategory.Any())
                {
                    <div class="chart-wrap">
                        <canvas id="catChart"></canvas>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No expenses yet this month.</p>
                }
            </div>
        </section>
    </div>
    <div class="col-md-6">
        <section class="workspace-panel h-100">
            <div class="panel-header">Budget Rules</div>
            <ul class="list-group list-group-flush">
                @foreach (var r in ruleResults)
                {
                    <li class="list-group-item rule-item sev-@r.Severity">
                        <div class="d-flex justify-content-between gap-3">
                            <strong>@r.CategoryName</strong>
                            <span class="badge bg-dark rule-badge">@r.RuleName</span>
                        </div>
                        <div class="small">@r.Message</div>
                    </li>
                }
                @if (!ruleResults.Any())
                {
                    <li class="list-group-item text-muted">No active budget rules.</li>
                }
            </ul>
        </section>
    </div>
</div>

<section class="workspace-panel mt-4 mb-4">
    <div class="panel-header">@insightHeading</div>
    <div class="p-3">
        <p class="mb-0">@insight</p>
    </div>
</section>

@section Scripts {
<script>
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(report.ByCategory));
    const labels = Object.keys(data);
    const values = Object.values(data);
    if (labels.length) {
        new Chart(document.getElementById('catChart'), {
                type: 'doughnut',
                data: { labels, datasets: [{ data: values }] },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: window.matchMedia('(max-width: 767px)').matches ? 'bottom' : 'right'
                        }
                    }
                }
            });
    }
</script>
}
