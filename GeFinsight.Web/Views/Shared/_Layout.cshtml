@inject Microsoft.AspNetCore.Identity.SignInManager<AppUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<AppUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · GeFinsight</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://code.jquery.com" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --surface: #f4f6f4;
            --ink: #202429;
            --muted: #5f666d;
            --line: #d9ded9;
            --brand: #17623f;
        }
        body {
            background: var(--surface);
            color: var(--ink);
            font-variant-numeric: tabular-nums;
            touch-action: manipulation;
        }
        a, .btn { transition: color .16s ease, background-color .16s ease, border-color .16s ease, box-shadow .16s ease; }
        a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible {
            outline: 3px solid rgba(23, 98, 63, .25);
            outline-offset: 2px;
        }
        .app-nav { background: #171c20; }
        .navbar-brand { font-weight:700; letter-spacing:0; }
        .app-shell { max-width: 1180px; }
        .page-title { text-wrap: balance; }
        .metric-grid { display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:1rem; }
        .metric-panel, .workspace-panel {
            background:#fff;
            border:1px solid var(--line);
            border-radius:8px;
        }
        .metric-panel { padding:1.25rem; box-shadow:0 6px 20px rgba(24, 32, 38, .04); }
        .metric-label { color:var(--muted); font-size:.9rem; }
        .metric-value { font-size:clamp(1.8rem, 4vw, 2.6rem); line-height:1.1; font-weight:700; }
        .panel-header {
            padding:1rem 1.25rem;
            border-bottom:1px solid var(--line);
            font-weight:650;
        }
        .chart-wrap { position:relative; height:320px; }
        .rule-item { border-left:6px solid transparent; }
        .sev-Ok { background:#eef8f2; border-left-color:#1f8a55; }
        .sev-Warning { background:#fff7dd; border-left-color:#d99b0b; }
        .sev-Breached { background:#ffe8e9; border-left-color:#c73546; }
        .rule-badge { border-radius:6px; }
        .table-wrap { overflow-x:auto; }
        .auth-panel { max-width:620px; }
        .auth-panel .form-control { min-height:52px; }
        @@media (max-width: 767.98px) {
            .metric-grid { grid-template-columns: 1fr; }
            .chart-wrap { height:260px; }
            .navbar .container { align-items:flex-start; }
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark app-nav mb-4">
    <div class="container app-shell">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">💰 GeFinsight</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="mainNav" class="collapse navbar-collapse">
            <div class="navbar-nav me-auto">
                <a class="nav-link text-light" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-link text-light" asp-controller="Transactions" asp-action="Index">Transactions</a>
                <a class="nav-link text-light" asp-controller="Budget" asp-action="Index">Budgets</a>
            </div>
            <div class="navbar-nav align-items-lg-center gap-2">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="text-light small text-break">@User.Identity?.Name</span>
                    <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="btn btn-outline-light btn-sm">Sign Out</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-area="Identity" asp-page="/Account/Login">Sign In</a>
                    <a class="btn btn-light btn-sm" asp-area="Identity" asp-page="/Account/Register">Register</a>
                }
            </div>
        </div>
    </div>
</nav>
<main class="container app-shell">
    @RenderBody()
</main>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
