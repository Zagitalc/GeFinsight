@model BudgetFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Edit budget rule" : "New budget rule";
}

<h1 class="page-title mb-3">@(isEdit ? "Edit Budget Rule" : "New Budget Rule")</h1>

<form method="post" class="workspace-panel p-4 mb-4" style="max-width: 640px;">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="CategoryName" class="form-label"></label>
        <select asp-for="CategoryName" asp-items="Model.Categories" class="form-select" required></select>
        <span asp-validation-for="CategoryName" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="RuleType" class="form-label"></label>
        <select asp-for="RuleType" asp-items="Html.GetEnumSelectList<BudgetRuleType>()" class="form-select" required></select>
        <span asp-validation-for="RuleType" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="LimitAmount" class="form-label"></label>
        <input asp-for="LimitAmount" type="number" step="0.01" min="0.01" inputmode="decimal" class="form-control" required />
        <span asp-validation-for="LimitAmount" class="text-danger small"></span>
    </div>
    <label class="form-check mb-4">
        <input asp-for="IsActive" class="form-check-input" />
        <span class="form-check-label">Active</span>
    </label>
    <div>
        <button type="submit" class="btn btn-primary">@(isEdit ? "Save Budget Rule" : "Create Budget Rule")</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>
