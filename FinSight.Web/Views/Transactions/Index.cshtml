@model IEnumerable<Transaction>
@{
    ViewData["Title"] = "Transactions";
    var year  = (int)ViewBag.Year;
    var month = (int)ViewBag.Month;
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <h1 class="page-title mb-0">Transactions — @(new DateTime(year, month, 1).ToString("MMMM yyyy"))</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Export" asp-route-format="csv">Export CSV</a>
        <a class="btn btn-primary" asp-action="Create">New Transaction</a>
    </div>
</div>

<div class="workspace-panel table-wrap mb-4">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr><th>Date</th><th>Category</th><th>Type</th><th class="text-end">Amount</th><th>Note</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Date.ToString("dd MMM")</td>
                    <td>@t.CategoryName</td>
                    <td><span class="badge bg-@(t.Type == TransactionType.Income ? "success" : "danger")">@t.Type</span></td>
                    <td class="text-end">£@Math.Abs(t.Amount).ToString("N2")</td>
                    <td class="text-muted text-break">@t.Note</td>
                    <td class="text-end">
                        <form method="post" asp-action="Delete" asp-route-id="@t.Id" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" aria-label="Delete transaction" onclick="return confirm('Delete this transaction?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No transactions this month.</td></tr>
            }
        </tbody>
    </table>
</div>
